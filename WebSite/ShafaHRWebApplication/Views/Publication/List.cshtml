                                                                @if (!string.IsNullOrEmpty(publication_Loop.Summary))
                                                                {
                                                                    <div class="text">@publication_Loop.Summary</div>
                                                                }
                                                            </div>
                                                        </div>
                                                    </td>
                                                </tr>
                                            }

                                        </tbody>
                                    </table>
                                </div>
                            }
                        </div>
                    </div>

