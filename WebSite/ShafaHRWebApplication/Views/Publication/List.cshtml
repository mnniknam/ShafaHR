                            }
                        </div>
                    </div>

                    <!--Tab-->
                    <div class="tab @((!string.IsNullOrEmpty(Context.Request.Query["t"]) && Context.Request.Query["t"] == "4") ? "active-tab" : "")" id="prod-reviews">
                        <div class="content">
                            @if (Model != null && Model.Where(u => u.Category == EnumPublicationCategory.Papers).Count() > 0)
                            {
                                <div class="table-outer">
                                    <table class="default-table">

                                        <tbody>
                                            @foreach (Publication publication_Loop in Model.Where(u => u.Category == EnumPublicationCategory.Papers))
                                            {
                                                <tr>
                                                    <td>
                                                        <div class="row">
                                                            <div class="service-block col-lg-6 col-md-6 col-sm-12">
                                                                <div class="inner-box">
                                                                    @if (publication_Loop.ThumbnailId != null)
                                                                    {
                                                                        <a href="@Url.Action("Details", "Publication", new { publication_Loop.Id })">
                                                                            <img class="icon2" src="@Url.Action("ShowFile", "File", new { Id = publication_Loop.ThumbnailId })" />
                                                                        </a>
                                                                    }
                                                                    else
                                                                    {
                                                                        <a href="@Url.Action("Details", "Publication", new { publication_Loop.Id })">
