@model IEnumerable<Publication>
@using ShafaHRCoreLib.Managers
@using ShafaHRCoreLib.Models
@{
    ViewData["Title"] = "انتشارات";
    Layout = "_LayoutRTL";
}

<!--Page Title-->

<section class="page-title" style="background-image: url(/RTL/images/background/10.jpg);">
    <div class="auto-container2">
        <div class="title-outer shabnam text-white">
            <h1 class="text-white">انتشارات</h1>
            <ul class="page-breadcrumb shabnam text-white">
                <li><a href="@Url.Action("Index", "Home")" class="text-white">خانه</a></li>
                <li class="text-white">فهرست انتشارات</li>
            </ul>
        </div>
    </div>
</section>
<!--End Page Title-->
<section class="pricing-section" style="margin-bottom: 100px">
    <div class="auto-container">

        <!--Product Info Tabs-->
        <div class="product-info-tabs">
            <!--Product Tabs-->
            <div class="prod-tabs tabs-box">
                <!--Tab Btns-->
                <ul class="tab-btns tab-buttons clearfix">
                    <li data-tab="#prod-details" class="tab-btn @((string.IsNullOrEmpty(Context.Request.Query["t"]) || Context.Request.Query["t"] == "1") ? "active-btn" : "")">متون علمی</li>
                    <li data-tab="#prod-spec" class="tab-btn @((!string.IsNullOrEmpty(Context.Request.Query["t"]) && Context.Request.Query["t"] == "2") ? "active-btn" : "")">کتب</li>
                    <li data-tab="#prod-reviews" class="tab-btn @((!string.IsNullOrEmpty(Context.Request.Query["t"]) && Context.Request.Query["t"] == "3") ? "active-btn" : "")">خبرنامه</li>
                    <li data-tab="#prod-reviews" class="tab-btn @((!string.IsNullOrEmpty(Context.Request.Query["t"]) && Context.Request.Query["t"] == "4") ? "active-btn" : "")">گزیده خلاصه مقالات اپیدمیولوژی و آمار</li>
                </ul>

                <!--Tabs Container-->
                <div class="tabs-content">

                    <!--Tab / Active Tab-->
                    <div class="tab @(string.IsNullOrEmpty(Context.Request.Query["t"]) ? "active-tab" : "")" id="prod-details">
                        <div class="content">
                            @if (Model != null && Model.Where(u => u.Category == EnumPublicationCategory.ScientificTexts).Count() > 0)
                            {
                                <div class="table-outer">
                                    <table class="default-table">

                                        <tbody>
                                            @foreach (Publication publication_Loop in Model.Where(u => u.Category == EnumPublicationCategory.ScientificTexts))
                                            {
                                                <tr>
                                                    <td>
                                                        <div class="row">
                                                            <div class="service-block col-lg-6 col-md-6 col-sm-12">
                                                                <div class="inner-box">
                                                                    @if (publication_Loop.ThumbnailId != null)
                                                                    {
                                                                        <a href="@Url.Action("Details", "Publication", new { publication_Loop.Id })">
                                                                            <img class="icon2" src="@Url.Action("ShowFile", "File", new { Id = publication_Loop.ThumbnailId })" />
                                                                        </a>
                                                                    }
                                                                    else
                                                                    {
                                                                        <a href="@Url.Action("Details", "Publication", new { publication_Loop.Id })">
                                                                            <img class="icon2" src="/RTL/images/centers.jpg" />
                                                                        </a>
                                                                    }

                                                                    <h5><a href="@Url.Action("Details", "Publication", new { publication_Loop.Id })" style="font-weight: bolder">@publication_Loop.Title</a></h5>
                                                                    <div class="text"></div>
                                                                </div>
                                                            </div>
                                                            <div class="service-block col-lg-6 col-md-6 col-sm-12">

                                                                @if (!string.IsNullOrEmpty(publication_Loop.Summary))
                                                                {
                                                                    <div class="text">@Html.Raw(publication_Loop.Summary?.Replace(Environment.NewLine, "<br/>"))</div>
                                                                }
                                                            </div>
                                                        </div>
                                                    </td>
                                                </tr>
                                            }

                                        </tbody>
                                    </table>
                                </div>
                            }
                        </div>
                    </div>

                    <!--Tab -->
                    <div class="tab @((!string.IsNullOrEmpty(Context.Request.Query["t"]) && Context.Request.Query["t"] == "2") ? "active-tab" : "")" id="prod-spec">
                        <div class="content">
                            @if (Model != null && Model.Where(u => u.Category == EnumPublicationCategory.Book).Count() > 0)
                            {
                                <div class="table-outer">
                                    <table class="default-table">

                                        <tbody>
