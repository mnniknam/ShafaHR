                                                                            <img class="icon2" src="/RTL/images/centers.jpg" />
                                                                        </a>
                                                                    }

                                                                    <h5><a href="@Url.Action("Details", "Publication", new { publication_Loop.Id })" style="font-weight: bolder">@publication_Loop.Title</a></h5>
                                                                    <div class="text"></div>
                                                                </div>
                                                            </div>
