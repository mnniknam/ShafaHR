@model ShafaHRCoreLib.Models.Publication
@using ShafaHRCoreLib.Models

@{
    ViewBag.Title = "پژوهشگران سلامت شفا";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="card-box" style="padding: 30px">

    <div class="row">
        <div class="col-md-12 bg-purple text-white" style="padding:15px;">
            @Html.ActionLink("انتشارات", "Index", null, null, new { style = "color: white;font-size: 14pt" })
            <span style="font-size: 8pt">&nbsp;&nbsp;>>&nbsp;&nbsp; </span>
            <span style="font-size: 14pt;color: #fff">تعریف انتشارات</span>
        </div>
    </div>

    <div class="row">
        <div class="col-md 12" style="height:10px">
        </div>
    </div>

    @using (Html.BeginForm("Create", "Publication", FormMethod.Post, new { enctype = "multipart/form-data" }))
    {

        <div class="form-horizontal p-20">

            @Html.ValidationSummary(true, "", new { @class = "text-danger" })
            @Html.AntiForgeryToken()
            @Html.HiddenFor(model => model.Id)


            <div class="form-group">
                @Html.LabelFor(model => model.Title, htmlAttributes: new { @class = "control-label col-md-2" })
                <div class="col-md-10">
                    @Html.EditorFor(model => model.Title, new { htmlAttributes = new { @class = "form-control", maxLenght = 1000 } })
                    @Html.ValidationMessageFor(model => model.Title, "", new { @class = "text-danger" })
                </div>
            </div>

            <div class="form-group">
                @Html.LabelFor(model => model.Category, htmlAttributes: new { @class = "control-label col-md-2" })
                <div class="col-md-10">
                    <select asp-for="Category"
                            asp-items="Html.GetEnumSelectList<EnumPublicationCategory>()"
                            class="form-control" style="font-family: 'iran'">
                    </select>
                    @Html.ValidationMessageFor(model => model.Category, "", new { @class = "text-danger" })
                </div>
            </div>

            <div class="form-group">
                @Html.LabelFor(model => model.Summary, htmlAttributes: new { @class = "control-label col-md-2" })
                <div class="col-md-10">
                    @Html.EditorFor(model => model.Summary, new { htmlAttributes = new { @class = "form-control", maxLenght = 3000 } })
                    @Html.ValidationMessageFor(model => model.Summary, "", new { @class = "text-danger" })
                </div>
            </div>

            <div class="form-group">
                <div class="col-md-offset-2 col-md-10">
                    <button type="submit" class="btn btn-purple btn-trans waves-effect w-md waves-success m-b-5">ثبت و ادامه</button>
                    <a class="btn btn-default btn-trans waves-effect w-md waves-default m-b-5" href="@Url.Action("Index", "Publication")">برگشت</a>
                    <img src="/assets/images/pleasewait.gif" id="loading" style="display: none" />
                    <label for="lblName" style="vertical-align: middle;" class="text-danger"></label>
                    <br />
                    <span style="color: green">@ViewBag.Message</span>
                </div>
            </div>

        </div>
    }

</div>

@section scripts {

    <script>

        function infarsi(evt) {
            var theEvent = evt || window.event;
            var key = theEvent.keyCode || theEvent.which;
            key = String.fromCharCode(key);
            var regex = /[^\u0600-\u06FF ]/;
            if (regex.test(key)) {
                theEvent.returnValue = false;
                alert('فقط حروف فارسی مورد قبول است');
                if (theEvent.preventDefault) theEvent.preventDefault();
            }
        }

    </script>
}
